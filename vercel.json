{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/analyse.js":      { "runtime": "edge" },
    "api/swatches-get.js": { "runtime": "edge" },
    "api/swatches-set.js": { "runtime": "edge" }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)",     "destination": "/index.html" }
  ]
}
